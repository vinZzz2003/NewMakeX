# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=make_x

# App Configuration
APP_NAME=RoboVenture
APP_VERSION=1.0.0
DEBUG_MODE=true

# Schedule Defaults
DEFAULT_MATCHES_PER_TEAM=4
DEFAULT_DURATION_MINUTES=2
DEFAULT_INTERVAL_MINUTES=1
DEFAULT_START_TIME=09:00
DEFAULT_END_TIME=17:00

# Arena Configuration
MAX_TEAMS_PER_ARENA=30

# Feature Flags
ENABLE_LUNCH_BREAK=true
LUNCH_START_HOUR=12
LUNCH_END_HOUR=13

# UI Configuration
PRIMARY_COLOR=#00CFFF
SECONDARY_COLOR=#FFFFD700
BACKGROUND_COLOR=#0E0630